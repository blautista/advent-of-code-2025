{
  "tasks": {
    "day": "deno run -P=day --env-file ./days/run.ts",
    "create-day": "deno run --allow-write ./internal/createDay.ts"
  },
  "imports": {
    "@std/assert": "jsr:@std/assert@1"
  },
  "fmt": {
    "lineWidth": 100,
    "newLineKind": "lf"
  },
  "permissions": {
    "day": {
      "read": ["./days/"],
      "write": ["./days/"],
      "net": ["adventofcode.com"],
      "env": {
        "allow": ["SESSION"]
      }
    }
  }
}
